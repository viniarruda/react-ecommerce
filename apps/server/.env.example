PORT=5001
NODE_ENV=development

# JWT signing secret — use a long random string in production
SECRET=dev-secret-change-in-production

# Prisma / Postgres connection string (takes precedence over individual vars below)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/react_ecommerce

# Legacy individual DB vars (used if DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_NAME=react_ecommerce
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432
