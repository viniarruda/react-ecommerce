PORT=5001
NODE_ENV=development

# JWT signing secret — use a long random string in production
SECRET=dev-secret-change-in-production

# Prisma / Postgres connection string (takes precedence over individual vars below)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/react_ecommerce

# Legacy individual DB vars (used if DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_NAME=react_ecommerce
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432

# ─── Seed data (used by `prisma db seed`) ───────────────────────────────────
# Credentials and store identity written when seeding the database.
SEED_ADMIN_EMAIL=admin@ecommerce.com
SEED_ADMIN_PASSWORD=admin123
SEED_CUSTOMER_EMAIL=customer@example.com
SEED_CUSTOMER_PASSWORD=customer123
SEED_STORE_NAME="React Ecommerce Store"
SEED_STORE_EMAIL=support@example.com
SEED_CURRENCY=USD
SEED_CURRENCY_SYMBOL=$
