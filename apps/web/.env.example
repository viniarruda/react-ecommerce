# ─── Runtime ────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5001

# ─── Branding (build-time) ──────────────────────────────────────────────────
# These are reflected in apps/web/config/branding.ts.
# Run `pnpm setup:client` to regenerate both this file and branding.ts interactively.
NEXT_PUBLIC_STORE_NAME="React Shop"
NEXT_PUBLIC_STORE_TAGLINE="Best Online Shopping Experience"
NEXT_PUBLIC_STORE_DESCRIPTION="Shop the latest products at unbeatable prices."
NEXT_PUBLIC_LOGO_ABBREV="R"
NEXT_PUBLIC_LOGO_URL=""

# ─── Theme ──────────────────────────────────────────────────────────────────
# Primary brand color (hex). Also set in apps/web/app/brand.css.
NEXT_PUBLIC_PRIMARY_COLOR="#0284c7"

# ─── Locale ─────────────────────────────────────────────────────────────────
# Reflected in branding.locale. ISO 4217 currency code + BCP-47 language tag.
NEXT_PUBLIC_CURRENCY="USD"
NEXT_PUBLIC_LOCALE="en-US"
