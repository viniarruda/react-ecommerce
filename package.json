{
  "name": "react-ecommerce",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:app": "turbo run dev --parallel --filter=@react-shop/api --filter=web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky install",
    "setup:client": "npx tsx scripts/setup-client.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "eslint-config-custom": "workspace:*",
    "husky": "^8.0.3",
    "prettier": "latest",
    "tsx": "^4.19.0",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {},
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "multer": "^2.2.0",
      "ws": "^8.21.0",
      "form-data": "^4.0.6",
      "axios": "^1.8.2",
      "nodemailer": "^9.0.1",
      "vite": "^6.4.3"
    }
  }
}