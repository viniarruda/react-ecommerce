{
  "name": "react-ecommerce",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:app": "turbo run dev --parallel --filter=@react-shop/api --filter=web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky install",
    "setup:client": "npx tsx scripts/setup-client.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "eslint-config-custom": "workspace:*",
    "husky": "^8.0.3",
    "prettier": "latest",
    "tsx": "^4.19.0",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {},
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "multer": "^2.2.0",
      "ws": "^8.21.0",
      "form-data": "^4.0.6",
      "axios": "^1.16.0",
      "nodemailer": "^9.0.1",
      "vite": "^6.4.3",
      "hono": "^4.12.25",
      "tmp": "^0.2.6",
      "js-cookie": "^3.0.7",
      "fast-uri": "^3.1.2",
      "next": "^15.5.16",
      "qs": "^6.15.2",
      "postcss": "^8.5.10",
      "tar": "^7.5.16",
      "serialize-javascript": "^7.0.5",
      "follow-redirects": "^1.16.0",
      "brace-expansion": "^2.0.1",
      "uuid": "^11.1.1",
      "handlebars": "^4.7.9",
      "fast-xml-parser": "^5.7.0",
      "minimatch": "^9.0.7",
      "rollup": "^4.59.0",
      "flatted": "^3.4.2",
      "picomatch": "^4.0.4",
      "defu": "^6.1.5",
      "lodash": "^4.18.0",
      "@hono/node-server": "^1.19.13",
      "path-to-regexp": "^8.2.0"
    }
  }
}